@article{hall_interspecific_1997,
	title = {Interspecific differences in the regeneration of artificial injuries on scleractinian corals},
	volume = {212},
	issn = {0022-0981},
	url = {https://www.sciencedirect.com/science/article/pii/S0022098196027608},
	doi = {10.1016/S0022-0981(96)02760-8},
	abstract = {Routine injury of corals occurs frequently and is caused by natural processes and human activities. Morphological theory predicts that sessile, marine animals are strongly committed to their place of settlement, will invest more resources into maintenance and defence than species that are more fugitive in nature (Jackson, 1979). In this study, I conducted several field experiments to determine if the regenerative ability of injured colonies differed among species with different morphologies, and if regeneration was influenced by the position of the injury within the colony or the type of injury. Eleven species exhibited a wide range of responses to damage, from little to no change to complete recovery within 71 to 286 days. Regenerative ability could be ranked according to morphological attributes for these species (arborescent{\textgreater}bushy{\textgreater}tabular{\textgreater}massive{\textgreater}submassive), demonstrating that morphology does influence the recovery of injuries. Regeneration of different types of injury and injuries located at different positions within a colony also varied among species. Repair of scraping injuries was greater than tissue injuries, while regrowth of a new branch was slowest of all. With the exception of Porites mayeri which repaired more of its central injury than its edge injury, recovery rate of central and edge injuries was not significantly different for Acropora robusta, A. hyacinthus, A. palifera, Pocillopora damcornis, and Porites lichen. These results imply that the amount of damage caused by an injury differs, both for the species it is inflicted upon, and the type of injury generated. The ability to recover from injuries is important in corals since poor regenerative ability can lead to a reduction in colony fitness.},
	number = {1},
	urldate = {2025-09-08},
	journal = {Journal of Experimental Marine Biology and Ecology},
	author = {Hall, Vicki R},
	month = may,
	year = {1997},
	keywords = {Regeneration, Damage, Branch removal, Coral reefs, Impact, Injury, Life-history, Scleractinian corals, Scraping injury, Tissue removal},
	pages = {9--23},
	file = {ScienceDirect Full Text PDF:files/4421/Hall - 1997 - Interspecific differences in the regeneration of artificial injuries on scleractinian corals.pdf:application/pdf;ScienceDirect Snapshot:files/4422/S0022098196027608.html:text/html},
}

